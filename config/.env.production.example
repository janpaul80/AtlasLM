# Patch 016A - production environment for the NEW server (atlaslm.cloud).
# Copy to <repo>/.env on 85.215.225.0 and fill in real secrets. Never commit this.

# --- Core URLs (now on the .cloud domain) ---
APP_URL=https://atlaslm.cloud
ATLAS_WEBHOOK_URL=https://atlaslm.cloud/api/v1/connections/google/notifications

# --- Database ---
DATABASE_URL=postgresql://atlas:CHANGE_ME@db:5432/atlaslm
POSTGRES_USER=atlas
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=atlaslm

# --- Mailer (Teams invite + claim emails) ---
SMTP_HOST=CHANGE_ME
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASSWORD=CHANGE_ME
MAIL_FROM=AtlasLM <no-reply@atlaslm.cloud>

# --- Google Drive connector ---
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME
GOOGLE_REDIRECT_URI=https://atlaslm.cloud/api/v1/connections/google/callback

# --- Model access (BYOK + Pro). Leave blank to disable a provider. ---
# These are read by the backend model router. See Patch 016B for mobile parity.
ATLAS_BYOK_ENABLED=true
ATLAS_PRO_ENABLED=true

# --- App secrets ---
SECRET_KEY=CHANGE_ME_LONG_RANDOM
